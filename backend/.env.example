# Backend config — Synapse Cognee
# Primary: Google Gemini (free tier, robust JSON schema tool-calling for Cognee)
# Fallback: Groq Native (OpenAI-compatible endpoint)
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here

# Groq fallback config
GROQ_API_KEY=your-groq-api-key-here
LLM_MODEL_FALLBACK=groq/llama-3.3-70b-versatile

# Access control — REQUIRED in any deployed environment.
# If unset, the backend fails closed (see main.py's verify_access_key).
SYNAPSE_ACCESS_KEY=generate-a-long-random-string-here

# Access key — used as a fallback seed for BYOK encryption key (database.py).
# Not currently enforced for API access; re-enable by uncommenting verify_llm_authorization in main.py.
SYNAPSE_ACCESS_KEY=generate-a-long-random-string-here

# The deployed frontend's exact origin — used for CORS allow-origins.
FRONTEND_URL=http://localhost:3000

MOCK_EMBEDDING=true
COGNEE_SKIP_CONNECTION_TEST=true

# Relational Database Config (SQLite or PostgreSQL)
# For local dev, SQLite is default. For Vercel/Prod, PostgreSQL (e.g. Neon, Supabase) is required.
# DATABASE_URL=postgresql://user:pass@host:port/dbname
# Or set individually:
# RELATIONAL_DB_PROVIDER=postgresql
# RELATIONAL_DB_HOST=localhost
# RELATIONAL_DB_PORT=5432
# RELATIONAL_DB_NAME=synapse
# RELATIONAL_DB_USERNAME=postgres
# RELATIONAL_DB_PASSWORD=postgres

# Vector Database Config (Optional, defaults to local LanceDB)
# VECTOR_DB_PROVIDER=qdrant  # or pgvector, milvus, weaviate
# VECTOR_DB_HOST=localhost
# VECTOR_DB_PORT=6333
# VECTOR_DB_NAME=synapse
# VECTOR_DB_USERNAME=admin
# VECTOR_DB_PASSWORD=admin
# VECTOR_DB_URL=https://...
# VECTOR_DB_KEY=your-vector-db-key

# Graph Database Config (Optional, defaults to local NetworkX)
# GRAPH_DATABASE_PROVIDER=neo4j
# GRAPH_DATABASE_HOST=localhost
# GRAPH_DATABASE_PORT=7687
# GRAPH_DATABASE_NAME=neo4j
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=password
# GRAPH_DATABASE_URL=neo4j://localhost:7687
